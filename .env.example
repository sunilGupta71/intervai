# Copy this file to `.env` and fill in your values

# MongoDB connection string
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/intervai
# Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.f5nxlui.mongodb.net/intervai?retryWrites=true&w=majority
MONGODB_URI= 

# Port the Express server listens on
PORT=3000

# OpenAI API key for generating role-specific questions
OPENAI_API_KEY=

